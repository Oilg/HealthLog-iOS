default_platform(:ios)

platform :ios do
  desc "Build and upload to TestFlight"
  lane :beta do
    api_key = app_store_connect_api_key(
      key_id:                  ENV["ASC_KEY_ID"],
      issuer_id:               ENV["ASC_ISSUER_ID"],
      key_content:             ENV["ASC_PRIVATE_KEY"],
      is_key_content_base64:   true,
    )

    # CI needs a temporary keychain — the runner has no login keychain password
    keychain_name     = "ci_signing"
    keychain_password = SecureRandom.hex(16)

    create_keychain(
      name:             keychain_name,
      password:         keychain_password,
      default_keychain: true,
      unlock:           true,
      timeout:          3600,
      lock_when_sleeps: false,
    )

    match(
      type:              "appstore",
      readonly:          true,
      api_key:           api_key,
      keychain_name:     keychain_name,
      keychain_password: keychain_password,
    )

    increment_build_number(
      build_number: Time.now.strftime("%Y%m%d%H%M%S"),
      xcodeproj:    "HealthLogSync.xcodeproj",
    )

    build_app(
      scheme:        "HealthLogSync",
      project:       "HealthLogSync.xcodeproj",
      export_method: "app-store",
      clean:         true,
    )

    upload_to_testflight(
      api_key:                           api_key,
      skip_waiting_for_build_processing: true,
    )
  ensure
    delete_keychain(name: keychain_name) rescue nil
  end

  desc "Regenerate provisioning profiles (run once after adding a new capability)"
  lane :renew_profiles do
    api_key = app_store_connect_api_key(
      key_id:                  ENV["ASC_KEY_ID"],
      issuer_id:               ENV["ASC_ISSUER_ID"],
      key_content:             ENV["ASC_PRIVATE_KEY"],
      is_key_content_base64:   true,
    )

    keychain_name     = "ci_signing"
    keychain_password = SecureRandom.hex(16)

    create_keychain(
      name:             keychain_name,
      password:         keychain_password,
      default_keychain: true,
      unlock:           true,
      timeout:          3600,
      lock_when_sleeps: false,
    )

    match(
      type:              "appstore",
      readonly:          false,
      force:             true,
      api_key:           api_key,
      keychain_name:     keychain_name,
      keychain_password: keychain_password,
    )
  ensure
    delete_keychain(name: keychain_name) rescue nil
  end
end
