default_platform(:ios)

platform :ios do
  desc "Build and upload to TestFlight"
  lane :beta do
    # App Store Connect API auth (no 2FA issues in CI)
    api_key = app_store_connect_api_key(
      key_id:        ENV["ASC_KEY_ID"],
      issuer_id:     ENV["ASC_ISSUER_ID"],
      key_content:   ENV["ASC_PRIVATE_KEY"],
      is_key_content_base64: true,
    )

    # Fetch distribution certificate and provisioning profile
    match(
      type:     "appstore",
      readonly: true,
      api_key:  api_key,
    )

    # Bump build number to current timestamp (ensures unique builds)
    increment_build_number(
      build_number: Time.now.strftime("%Y%m%d%H%M"),
      xcodeproj:    "HealthLogSync.xcodeproj",
    )

    # Build
    build_app(
      scheme:          "HealthLogSync",
      xcodeproj:       "HealthLogSync.xcodeproj",
      export_method:   "app-store",
      clean:           true,
    )

    # Upload to TestFlight (don't wait for processing — saves CI time)
    upload_to_testflight(
      api_key:                          api_key,
      skip_waiting_for_build_processing: true,
    )
  end
end
